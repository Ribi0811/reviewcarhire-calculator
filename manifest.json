{
  "manifest_version": 3,
  "name": "ReviewCarHire - Car Rental Calculator",
  "version": "1.0.0",
  "description": "Calculate the true cost of car rental at airports. Compare prices and find the best car hire deals globally.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ReviewCarHire - Car Rental Calculator"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}